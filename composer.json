{
    "name": "tegroton/ton-token-purchase-script",
    "description": "Production-ready Tegro.Money + Telegram-bot template for selling any TON-network token. Webhook signature verification, PDO prepared statements, idempotent payouts.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tegro",
        "tegro-money",
        "telegram",
        "telegram-bot",
        "payments",
        "fiat-onramp",
        "ton",
        "ton-blockchain",
        "rub",
        "sbp",
        "webhook",
        "php"
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-pdo": "*",
        "psr/log": "^3.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11",
        "phpstan/phpstan-phpunit": "^1.4",
        "phpstan/phpstan-strict-rules": "^1.6",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "Tegro\\Purchase\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tegro\\Purchase\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse",
        "phpcs": "phpcs",
        "phpcbf": "phpcbf",
        "check": [
            "@phpstan",
            "@phpcs",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
