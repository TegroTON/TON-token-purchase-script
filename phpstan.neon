includes:
    - vendor/phpstan/phpstan-strict-rules/rules.neon
    - vendor/phpstan/phpstan-phpunit/extension.neon
    - vendor/phpstan/phpstan-phpunit/rules.neon

parameters:
    level: 8
    paths:
        - src
        - tests
        - public
    excludePaths:
        - vendor
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # `final readonly class` for value objects causes the strict-rules
        # extension to flag the property as needing a setter — readonly props
        # by definition have no setter, so the rule contradicts itself here.
        - identifier: missingType.iterableValue
          path: src/Postback/Handler.php
        # PHPStan strict-rules flags every static-style call on $this->assert*
        # in test files as "dynamic call to static method" even with the
        # phpstan-phpunit extension installed; suppress for the tests folder.
        - '#Dynamic call to static method PHPUnit\\Framework\\Assert::.*#'
