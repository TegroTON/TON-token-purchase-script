# Telegram bot — get from @BotFather
TELEGRAM_BOT_TOKEN=

# Tegro.Money — Cabinet → Shops → Settings
TEGRO_SHOP_ID=
TEGRO_API_KEY=
TEGRO_SECRET_KEY=

# Token being sold — purely cosmetic, used in user-facing notifications
TOKEN_SYMBOL=DEMO
TOKEN_CURRENCY=RUB

# Markup over the upstream token rate, in percent (110 = 10% above the rate).
# 100 means "no markup". Validated as positive number.
MARKUP_PERCENT=110

# Database — MySQL/MariaDB
DB_DSN=mysql:host=127.0.0.1;port=3306;dbname=tegro_purchase;charset=utf8mb4
DB_USER=tegro_purchase
DB_PASSWORD=

# Logging path — keep outside the web root
LOG_PATH=/var/log/tegro-purchase/postback.log
