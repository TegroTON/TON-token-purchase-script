<?xml version="1.0"?>
<ruleset name="Tegro Purchase">
    <description>PSR-12 with strict type declarations.</description>

    <file>src</file>
    <file>tests</file>
    <file>public</file>

    <exclude-pattern>vendor/</exclude-pattern>

    <rule ref="PSR12"/>

    <arg name="colors"/>
    <arg name="parallel" value="4"/>
    <arg value="sp"/>
</ruleset>
